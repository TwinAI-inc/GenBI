# ── GenBI Auth Configuration ──────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# PostgreSQL connection string
DATABASE_URL=postgresql://localhost/genbi_auth

# Secret key for JWT signing (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# Secret key for Flask session / CSRF (generate same way)
FLASK_SECRET_KEY=change-me-to-another-random-string

# ── Email Provider ────────────────────────────────────────────────────────────
# Set to "gmail" to use Gmail API, or "smtp" for SMTP, or "console" for dev mode.
EMAIL_PROVIDER=console

# Gmail API OAuth2 (only if EMAIL_PROVIDER=gmail)
# Generate a refresh token via Google OAuth2 playground or a one-time script.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_SENDER=you@gmail.com

# SMTP (only if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER=

# ── App Settings ──────────────────────────────────────────────────────────────
# Base URL for password reset links (no trailing slash)
APP_BASE_URL=http://localhost:8000

# Password reset token expiry in minutes
RESET_TOKEN_EXPIRY_MINUTES=30

# ── Google OAuth (for user login — separate from Gmail API sending) ──────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8000/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Billing / Stripe (optional) ─────────────────────────────────────────────
# Leave empty for mock billing mode (subscriptions activate instantly without payment).
# Set these to enable real Stripe payment processing.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_BUSINESS=
STRIPE_SUCCESS_URL=http://localhost:8000/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:8000/billing/cancel

# ── Azure Communication Services (if EMAIL_PROVIDER=acs) ─────────────────
AZURE_COMMUNICATION_CONNECTION_STRING=
ACS_EMAIL_SENDER=

# ── Production Settings ──────────────────────────────────────────────────────
# FLASK_ENV=production
# CORS_ORIGINS=https://yourdomain.com
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0
